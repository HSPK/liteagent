{
  "name": "agents",
  "version": "0.1.0",
  "description": "A message-driven framework for collaborative, long-lived agents.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "agents": "./bin/agents.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
