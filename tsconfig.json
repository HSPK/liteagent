{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node", "react"]
  },
  "include": ["src/**/*.js", "src/**/*.ts", "bin/**/*.js", "bin/**/*.ts", "test/**/*.js", "test/**/*.ts"]
}
